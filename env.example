## App
NEXT_PUBLIC_APP_NAME="Revenue & Cost Intelligence"

## NextAuth
# Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
AUTH_SECRET="replace_me_with_a_long_random_string"
AUTH_TRUST_HOST="true"

## Azure AD / Entra ID (optional for MVP)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

## Postgres (Supabase)
# Get your connection string from Supabase Dashboard > Settings > Database > Connection string
# Recommended for apps: use the Connection Pooler (Session/Transaction) on port 6543 (host usually ends with `.pooler.supabase.com`)
# For migrations: use the Direct DB host (usually `db.<PROJECT_REF>.supabase.co`) on port 5432
#
# Examples:
# - Pooler (Session):     postgresql://postgres.<PROJECT_REF>:[YOUR-PASSWORD]@<REGION>.pooler.supabase.com:6543/postgres?sslmode=require
# - Pooler (Transaction): postgresql://postgres.<PROJECT_REF>:[YOUR-PASSWORD]@<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# - Direct DB (migrate):  postgresql://postgres:[YOUR-PASSWORD]@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:[YOUR-PASSWORD]@<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require"

